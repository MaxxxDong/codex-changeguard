{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.invalid/codex-changeguard/upstream-submission-capsule.schema.json",
  "title": "UpstreamSubmissionCapsule",
  "description": "Ticket 10 local-only preview capsule. Never SUBMITTED/POSTED; external_write always false.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "capsule_id",
    "mode",
    "locality",
    "repair_authorized",
    "external_write",
    "requires_ticket11_confirmation",
    "status",
    "route",
    "github_issue_form",
    "form_filename",
    "duplicate",
    "maintainer_value_gate",
    "form_snapshot",
    "doctor_inclusion",
    "privacy_review",
    "observed_facts",
    "user_reports",
    "hypotheses",
    "error_strings",
    "command_strings",
    "route_rationale",
    "draft_title",
    "draft_labels",
    "private_report_guidance",
    "support_guidance",
    "discussion_guidance",
    "capsule_content_sha256"
  ],
  "properties": {
    "schema_version": { "const": 1 },
    "capsule_id": {
      "type": "string",
      "pattern": "^usc_[a-f0-9]{24}$"
    },
    "mode": { "const": "preview_only" },
    "locality": { "const": "local_only" },
    "repair_authorized": { "const": false },
    "external_write": { "const": false },
    "requires_ticket11_confirmation": { "const": true },
    "status": {
      "enum": [
        "PREVIEW_READY",
        "PREVIEW_BLOCKED",
        "GATE_FAILED",
        "ROUTED_PRIVATE"
      ]
    },
    "route": {
      "enum": [
        "GITHUB_ISSUE",
        "GITHUB_DISCUSSIONS",
        "BUGCROWD",
        "OPENAI_SUPPORT"
      ]
    },
    "github_issue_form": {
      "type": ["string", "null"],
      "enum": ["APP", "CLI", "EXTENSION", "OTHER", null]
    },
    "form_filename": {
      "type": ["string", "null"],
      "maxLength": 128
    },
    "duplicate": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "state",
        "matched_issue_id",
        "matched_issue_url",
        "evidence_delta_material",
        "evidence_delta_hash",
        "recommendation",
        "draft_body",
        "draft_comment",
        "cross_link_issue_ids"
      ],
      "properties": {
        "state": {
          "enum": ["EXACT_DUPLICATE", "RELATED_NOT_SAME", "NEW_INCIDENT"]
        },
        "matched_issue_id": { "type": ["string", "null"], "maxLength": 128 },
        "matched_issue_url": { "type": ["string", "null"], "maxLength": 512 },
        "evidence_delta_material": { "type": "boolean" },
        "evidence_delta_hash": {
          "type": ["string", "null"],
          "pattern": "^[a-f0-9]{64}$"
        },
        "recommendation": {
          "enum": [
            "subscribe_or_upvote",
            "comment_with_delta",
            "open_new",
            "cross_link_related",
            "private_report",
            "contact_support",
            "open_discussion",
            "blocked"
          ]
        },
        "draft_body": { "type": ["string", "null"], "maxLength": 16384 },
        "draft_comment": { "type": ["string", "null"], "maxLength": 8192 },
        "cross_link_issue_ids": {
          "type": "array",
          "maxItems": 32,
          "items": { "type": "string", "maxLength": 128 }
        }
      }
    },
    "maintainer_value_gate": {
      "type": "object",
      "additionalProperties": false,
      "required": ["passed", "checks", "failed_ids"],
      "properties": {
        "passed": { "type": "boolean" },
        "checks": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["id", "passed", "detail"],
            "properties": {
              "id": { "type": "string" },
              "passed": { "type": "boolean" },
              "detail": { "type": "string" }
            }
          }
        },
        "failed_ids": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    },
    "form_snapshot": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "snapshot_id",
        "fetched_at",
        "main_commit",
        "integrity_sha256",
        "freshness",
        "stale_reason",
        "age_ms",
        "forms",
        "source"
      ],
      "properties": {
        "snapshot_id": { "type": "string" },
        "fetched_at": { "type": "string" },
        "main_commit": {
          "type": "string",
          "pattern": "^[a-f0-9]{40}$"
        },
        "integrity_sha256": {
          "type": "string",
          "pattern": "^[a-f0-9]{64}$"
        },
        "freshness": { "enum": ["fresh", "stale"] },
        "stale_reason": { "type": ["string", "null"] },
        "age_ms": { "type": "integer", "minimum": 0 },
        "forms": {
          "type": "array",
          "minItems": 4,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["filename", "blob_sha", "form", "notes"],
            "properties": {
              "filename": {
                "type": "string",
                "pattern": "^[0-9]+-[a-z0-9][a-z0-9.-]*\\.ya?ml$"
              },
              "blob_sha": {
                "type": "string",
                "pattern": "^[a-f0-9]{40}$"
              },
              "form": {
                "type": ["string", "null"],
                "enum": ["APP", "CLI", "EXTENSION", "OTHER", "FEATURE", "DOCS", null]
              },
              "notes": { "type": "string", "maxLength": 512 }
            }
          }
        },
        "source": {
          "enum": ["bundled_immutable", "transport_refresh"]
        }
      }
    },
    "doctor_inclusion": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "included",
        "inclusion_manifest",
        "sanitized_summary",
        "refused_reasons",
        "secrets_redacted",
        "paths_redacted"
      ],
      "properties": {
        "included": { "type": "boolean" },
        "inclusion_manifest": {
          "type": "array",
          "items": { "type": "string" }
        },
        "sanitized_summary": {
          "description": "Bounded allowlisted doctor summary only; additionalProperties false.",
          "oneOf": [
            { "type": "null" },
            {
              "type": "object",
              "additionalProperties": false,
              "properties": {
                "schema_version": {
                  "type": ["string", "number", "boolean", "null", "array", "object"]
                },
                "codex_version": {
                  "type": ["string", "number", "boolean", "null", "array", "object"]
                },
                "cli_version": {
                  "type": ["string", "number", "boolean", "null", "array", "object"]
                },
                "platform": {
                  "type": ["string", "number", "boolean", "null", "array", "object"]
                },
                "os": {
                  "type": ["string", "number", "boolean", "null", "array", "object"]
                },
                "arch": {
                  "type": ["string", "number", "boolean", "null", "array", "object"]
                },
                "node_version": {
                  "type": ["string", "number", "boolean", "null", "array", "object"]
                },
                "rust_version": {
                  "type": ["string", "number", "boolean", "null", "array", "object"]
                },
                "shell": {
                  "type": ["string", "number", "boolean", "null", "array", "object"]
                },
                "sandbox_mode": {
                  "type": ["string", "number", "boolean", "null", "array", "object"]
                },
                "features": {
                  "type": ["string", "number", "boolean", "null", "array", "object"]
                },
                "mcp_servers": {
                  "type": ["string", "number", "boolean", "null", "array", "object"]
                },
                "plugins": {
                  "type": ["string", "number", "boolean", "null", "array", "object"]
                },
                "skills": {
                  "type": ["string", "number", "boolean", "null", "array", "object"]
                },
                "hooks": {
                  "type": ["string", "number", "boolean", "null", "array", "object"]
                },
                "auth_mode": {
                  "type": ["string", "number", "boolean", "null", "array", "object"]
                },
                "network_mode": {
                  "type": ["string", "number", "boolean", "null", "array", "object"]
                },
                "workdir_alias": {
                  "type": ["string", "number", "boolean", "null", "array", "object"]
                },
                "status": {
                  "type": ["string", "number", "boolean", "null", "array", "object"]
                },
                "checks": {
                  "type": ["string", "number", "boolean", "null", "array", "object"]
                },
                "summary": {
                  "type": ["string", "number", "boolean", "null", "array", "object"]
                }
              }
            }
          ]
        },
        "refused_reasons": {
          "type": "array",
          "items": { "type": "string" }
        },
        "secrets_redacted": { "type": "boolean" },
        "paths_redacted": { "type": "boolean" }
      }
    },
    "privacy_review": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "passed",
        "secrets_redacted",
        "paths_redacted",
        "session_excluded",
        "injection_quarantined",
        "quarantine"
      ],
      "properties": {
        "passed": {
          "type": "boolean",
          "description": "Exactly no injection AND secrets_redacted AND paths_redacted AND session_excluded."
        },
        "secrets_redacted": { "type": "boolean" },
        "paths_redacted": { "type": "boolean" },
        "session_excluded": { "type": "boolean" },
        "injection_quarantined": { "type": "boolean" },
        "quarantine": {
          "description": "Exact QuarantineRecord shape or null; additionalProperties false.",
          "oneOf": [
            { "type": "null" },
            {
              "type": "object",
              "additionalProperties": false,
              "required": [
                "quarantined",
                "reason",
                "original_sha256",
                "placeholder"
              ],
              "properties": {
                "quarantined": { "const": true },
                "reason": { "type": "string", "minLength": 1, "maxLength": 128 },
                "original_sha256": {
                  "type": "string",
                  "pattern": "^[a-f0-9]{64}$"
                },
                "placeholder": {
                  "type": "string",
                  "minLength": 1,
                  "maxLength": 256
                }
              }
            }
          ]
        }
      }
    },
    "observed_facts": {
      "type": "array",
      "items": { "type": "string" }
    },
    "user_reports": {
      "type": "array",
      "items": { "type": "string" }
    },
    "hypotheses": {
      "type": "array",
      "items": { "type": "string" }
    },
    "error_strings": {
      "type": "array",
      "items": { "type": "string" }
    },
    "command_strings": {
      "type": "array",
      "items": { "type": "string" }
    },
    "route_rationale": { "type": "string" },
    "draft_title": { "type": ["string", "null"] },
    "draft_labels": {
      "type": "array",
      "items": { "type": "string" }
    },
    "private_report_guidance": { "type": ["string", "null"] },
    "support_guidance": { "type": ["string", "null"] },
    "discussion_guidance": { "type": ["string", "null"] },
    "capsule_content_sha256": {
      "type": "string",
      "pattern": "^[a-f0-9]{64}$"
    }
  }
}
