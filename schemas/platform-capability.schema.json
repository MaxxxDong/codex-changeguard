{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.invalid/codex-changeguard/platform-capability.schema.json",
  "title": "PlatformCapabilityReport",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "adapter",
    "platform",
    "runtime_domain",
    "status",
    "writes_enabled",
    "mutation_disabled_by_default",
    "discoveries",
    "gaps",
    "support_receipt",
    "network_used",
    "target_mutated",
    "full_support_claimed"
  ],
  "properties": {
    "schema_version": { "const": 1 },
    "adapter": {
      "enum": ["unknown", "macos", "windows", "linux", "wsl", "enterprise_managed"]
    },
    "platform": {
      "enum": ["unknown", "macos", "windows", "linux", "wsl", "enterprise_managed"]
    },
    "runtime_domain": {
      "enum": ["native_linux", "wsl_distro", "windows_host", "macos_host", "unknown"]
    },
    "status": {
      "enum": ["READ_ONLY", "LIMITED", "PREVIEW", "FULL"]
    },
    "writes_enabled": { "type": "boolean" },
    "mutation_disabled_by_default": { "type": "boolean" },
    "discoveries": {
      "type": "array",
      "maxItems": 64,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "kind",
          "path_alias",
          "path_hash",
          "present",
          "readable",
          "content_sha256",
          "refused_reason"
        ],
        "properties": {
          "kind": {
            "enum": ["cli_instance", "config", "log", "user_cache", "managed_policy"]
          },
          "path_alias": { "type": "string", "maxLength": 128 },
          "path_hash": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
          "present": { "type": "boolean" },
          "readable": { "type": "boolean" },
          "content_sha256": {
            "anyOf": [
              { "type": "null" },
              { "type": "string", "pattern": "^[a-f0-9]{64}$" }
            ]
          },
          "refused_reason": { "type": ["string", "null"], "maxLength": 128 }
        }
      }
    },
    "gaps": {
      "type": "array",
      "maxItems": 32,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "summary", "status"],
        "properties": {
          "id": { "type": "string", "maxLength": 64 },
          "summary": { "type": "string", "maxLength": 512 },
          "status": {
            "enum": ["READ_ONLY", "LIMITED", "PREVIEW", "FULL"]
          }
        }
      }
    },
    "support_receipt": {
      "type": ["object", "null"],
      "additionalProperties": false,
      "required": [
        "schema_version",
        "scenario_ids",
        "claimed_status",
        "adapter",
        "real_machine",
        "notes"
      ],
      "properties": {
        "schema_version": { "const": 1 },
        "scenario_ids": {
          "type": "array",
          "minItems": 1,
          "maxItems": 64,
          "items": { "type": "string", "maxLength": 128 }
        },
        "claimed_status": {
          "enum": ["READ_ONLY", "LIMITED", "PREVIEW", "FULL"]
        },
        "adapter": {
          "enum": ["unknown", "macos", "windows", "linux", "wsl", "enterprise_managed"]
        },
        "real_machine": { "type": "boolean" },
        "notes": {
          "type": "array",
          "maxItems": 16,
          "items": { "type": "string", "maxLength": 256 }
        }
      }
    },
    "network_used": { "const": false },
    "target_mutated": { "const": false },
    "full_support_claimed": { "const": false }
  }
}
