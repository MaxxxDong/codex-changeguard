{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.invalid/codex-changeguard/impact-contract.schema.json",
  "title": "ImpactContract",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "claim_id",
    "statement",
    "provenance",
    "source_spans",
    "local_matcher",
    "confidence",
    "counterevidence",
    "suggested_probe_ids"
  ],
  "properties": {
    "schema_version": {"const": 1},
    "claim_id": {"type": "string", "pattern": "^[a-z0-9][a-z0-9._-]{0,127}$"},
    "statement": {"type": "string", "minLength": 1, "maxLength": 4096},
    "provenance": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "enum": ["official", "local_observed", "user_reported", "model_inferred", "unknown"]
      }
    },
    "source_spans": {
      "type": "array",
      "minItems": 1,
      "maxItems": 32,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["source_id", "source_type", "locator", "trust"],
        "properties": {
          "source_id": {"type": "string", "maxLength": 256},
          "source_type": {"enum": ["doc", "release", "commit", "file", "hunk", "issue", "probe"]},
          "locator": {"type": "string", "maxLength": 2048},
          "trust": {"enum": ["official", "maintainer", "user_reported", "community", "local_observed"]}
        }
      }
    },
    "local_matcher": {
      "enum": ["matched", "not_matched", "insufficient_local_facts", "not_applicable", "error"]
    },
    "confidence": {"type": "number", "minimum": 0, "maximum": 1},
    "counterevidence": {
      "type": "array",
      "maxItems": 32,
      "items": {"type": "string", "maxLength": 2048}
    },
    "suggested_probe_ids": {
      "type": "array",
      "maxItems": 16,
      "uniqueItems": true,
      "items": {"type": "string", "pattern": "^[a-z0-9][a-z0-9._-]{0,127}$"}
    },
    "verdict_lock": {
      "enum": ["model_may_hypothesize", "probe_supports", "probe_refutes", "human_decision_required"]
    }
  }
}
